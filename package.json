{
  "name": "n8n-nodes-siliconflow-ai",
  "version": "0.5.0",
  "description": "n8n community node for SiliconFlow (硅基流动). Zero runtime dependencies. Provides a SiliconFlow action node (Chat / Vision / Embeddings / Image / Rerank / Audio TTS+ASR) and a LangChain-compatible Chat Model node for AI Agents. Installs cleanly without ERESOLVE langchain peer-dependency conflicts.",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "siliconflow",
    "silicon-flow",
    "硅基流动",
    "ai",
    "llm",
    "chat-completion",
    "embedding",
    "image-generation",
    "rerank",
    "vision",
    "vision-language-model",
    "multimodal",
    "audio",
    "tts",
    "text-to-speech",
    "speech-synthesis",
    "asr",
    "speech-to-text",
    "speech-recognition",
    "cosyvoice",
    "sensevoice",
    "qwen",
    "glm",
    "deepseek",
    "ai-agent",
    "tools-calling",
    "function-calling"
  ],
  "license": "MIT",
  "author": {
    "name": "nam2009",
    "email": "nam2009@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nam2009/n8n-nodes-siliconflow-ai.git"
  },
  "bugs": {
    "url": "https://github.com/nam2009/n8n-nodes-siliconflow-ai/issues"
  },
  "homepage": "https://github.com/nam2009/n8n-nodes-siliconflow-ai#readme",
  "main": "index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "build:watch": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts",
    "lint:fix": "eslint nodes credentials --ext .ts --fix",
    "format": "prettier --write \"nodes/**/*.ts\" \"credentials/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@types/node": "^20.10.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0",
    "@langchain/core": "*",
    "@langchain/openai": "*"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "@langchain/openai": {
      "optional": true
    }
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SiliconFlowApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SiliconFlow/SiliconFlow.node.js",
      "dist/nodes/SiliconFlowChatModel/SiliconFlowChatModel.node.js"
    ]
  }
}
